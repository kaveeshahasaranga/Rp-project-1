PORT=5000
MONGODB_URI=mongodb://localhost:27017/ux-analyzer
JWT_SECRET=change-this-to-a-strong-random-secret-in-production
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:3000

# Python Microservice URLs (use service names when running in Docker)
COGNITIVE_URL=http://localhost:8001
TOUCH_URL=http://localhost:8002
SALIENCY_URL=http://localhost:8003
SERVICE_TIMEOUT_MS=60000

# Optional: Redis (for Celery task queue)
REDIS_URL=redis://localhost:6379/0
